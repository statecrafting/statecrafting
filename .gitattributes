# Enforce LF line endings for all text files in this repository.
# This prevents "LF will be replaced by CRLF" warnings on Windows
# and ensures consistent line endings across all platforms.

# Default: normalize all text files to LF on commit
* text=auto eol=lf

# --- Source code ---
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.rs        text eol=lf

# --- Config / markup ---
*.json      text eol=lf
*.jsonc     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.html      text eol=lf
*.css       text eol=lf

# --- Docs ---
*.md        text eol=lf
*.mdx       text eol=lf
*.txt       text eol=lf

# --- Shell / config ---
*.sh        text eol=lf
*.conf      text eol=lf
.env*       text eol=lf
Dockerfile* text eol=lf
*.dockerfile text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf

# --- Binary: never touch line endings ---
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.tgz       binary
*.node      binary

# Binary test fixtures (e.g. in a vendored build workspace) must never be
# line-ending normalized.
*.bin binary
