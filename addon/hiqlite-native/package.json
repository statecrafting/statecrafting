{
  "name": "@statecrafting/hiqlite-native",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/statecrafting/statecrafting.git",
    "directory": "addon/hiqlite-native"
  },
  "spec-spine": { "spec": "003-hiqlite-native" },
  "description": "In-process hiqlite (cache/KV + counters) as a napi-rs native addon. Prebuilt per-platform binaries ship as optional dependencies (statecrafting spec 003).",
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "engines": { "node": ">=24" },
  "files": [
    "LICENSE",
    "index.js",
    "index.d.ts"
  ],
  "napi": {
    "binaryName": "hiqlite-native",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "create-npm-dirs": "napi create-npm-dirs",
    "artifacts": "napi artifacts"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.1.5"
  }
}
